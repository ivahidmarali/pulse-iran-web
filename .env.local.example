NEXT_PUBLIC_API_URL=https://palsiran.com/api
NEXT_PUBLIC_SITE_URL=https://palsiran.com
INTERNAL_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_token_here

# Bing Webmaster Tools — get from https://www.bing.com/webmasters/
# 1. Add site → Auto-verify via XML meta tag
# 2. Paste the content value of <meta name="msvalidate.01"> here
NEXT_PUBLIC_BING_SITE_VERIFICATION=your_bing_verification_token_here

# Bing Webmaster API key — get from Bing WMT → Settings → API Access
# Used to auto-submit sitemaps to Bing on every sitemap regeneration
BING_WEBMASTER_API_KEY=your_bing_api_key_here
